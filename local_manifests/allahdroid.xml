<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <!-- build_id.mk -->
    <project path="build/core" name="build_core" revision="main">
        <copyfile dest="build/core/build_id.mk" src="build/core/build_id.mk"/>
    </project>

    <!-- обои (3 размера) -->
    <project path="frameworks/base/core/res/res/drawable-nodpi" name="frameworks_base_res_drawable" revision="main">
        <copyfile dest="frameworks/base/core/res/res/drawable-nodpi/default_wallpaper.jpg" src="default_wallpaper.jpg"/>
    </project>
    <project path="frameworks/base/core/res/res/drawable-sw600dp-nodpi" name="frameworks_base_res_drawable_sw600" revision="main">
        <copyfile dest="frameworks/base/core/res/res/drawable-sw600dp-nodpi/default_wallpaper.jpg" src="default_wallpaper.jpg"/>
    </project>
    <project path="frameworks/base/core/res/res/drawable-sw720dp-nodpi" name="frameworks_base_res_drawable_sw720" revision="main">
        <copyfile dest="frameworks/base/core/res/res/drawable-sw720dp-nodpi/default_wallpaper.jpg" src="default_wallpaper.jpg"/>
    </project>

    <!-- SetupWizard (Provision) -->
    <project path="packages/apps/Provision" name="Provision" revision="main"/>

    <!-- рут права (SuperSU апк + su бинарник) -->
    <project path="device/generic/goldfish/root_files" name="goldfish_root_files" revision="main">
        <copyfile dest="device/generic/goldfish/root_files/app/SuperSU.apk" src="app/SuperSU.apk"/>
        <copyfile dest="device/generic/goldfish/root_files/app/Android.mk" src="app/Android.mk"/>
        <copyfile dest="device/generic/goldfish/root_files/xbin/su" src="xbin/su"/>
        <copyfile dest="device/generic/goldfish/root_files/xbin/Android.mk" src="xbin/Android.mk"/>
    </project>

    <!-- правка init.goldfish.rc -->
    <project path="device/generic/goldfish" name="goldfish_init" revision="main">
        <copyfile dest="device/generic/goldfish/init.goldfish.rc" src="init.goldfish.rc"/>
    </project>

    <!-- звук explosion.ogg -->
    <project path="packages/apps/Settings/res/raw" name="Settings_raw" revision="main">
        <copyfile dest="packages/apps/Settings/res/raw/explosion.ogg" src="explosion.ogg"/>
    </project>

    <!-- правки в DeviceInfoSettings.java -->
    <project path="packages/apps/Settings/src/com/android/settings" name="Settings_src" revision="main">
        <copyfile dest="packages/apps/Settings/src/com/android/settings/DeviceInfoSettings.java" src="DeviceInfoSettings.java"/>
    </project>

    <!-- правки в android_filesystem_config.h и init.c -->
    <project path="system/core/include/private" name="system_core_config" revision="main">
        <copyfile dest="system/core/include/private/android_filesystem_config.h" src="android_filesystem_config.h"/>
    </project>
    <project path="system/core/init" name="system_core_init" revision="main">
        <copyfile dest="system/core/init/init.c" src="init.c"/>
    </project>
</manifest>